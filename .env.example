# ====== NEXUS AI — Environment Variables ======
# Copy file này thành .env (dev) hoặc set qua `fly secrets set` (production)

# Database (SQLite — Fly volume mount tại /data)
DATABASE_URL=file:/data/custom.db

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx

# GitHub OAuth App credentials (https://github.com/settings/developers)
GITHUB_CLIENT_ID=xxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxx

# App URL (domain production — KHÔNG có slash cuối)
# Dev: http://localhost:3000
# Fly: https://nexus-ai-app.fly.dev
NEXT_PUBLIC_APP_URL=https://nexus-ai-app.fly.dev
APP_URL=https://nexus-ai-app.fly.dev

# Chat service URL (Socket.io)
# Dev: (empty — dùng XTransformPort=3001 qua Caddy)
# Fly: https://nexus-ai-chat.fly.dev
NEXT_PUBLIC_CHAT_URL=https://nexus-ai-chat.fly.dev
