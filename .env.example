# ====== NEXUS AI — Environment Variables ======
# Copy file này thành .env và điền giá trị thật
# Docs: https://github.com/vanhoi04082006-pixel/Nexus-AI

# ────────────────────────────────────────────────────────────
# Database (SQLite — local file)
# ────────────────────────────────────────────────────────────
DATABASE_URL=file:./db/custom.db

# ────────────────────────────────────────────────────────────
# OpenRouter API Keys (BẮT BUỘC để AI chạy)
# Hỗ trợ multi-key rotation — tự switch khi 1 key bị 429
# Lấy key miễn phí tại: https://openrouter.ai/keys
# ────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx

# (Tùy chọn) Thêm nhiều key để tăng throughput + tránh rate-limit
# OPENROUTER_API_KEY_2=sk-or-v1-xxxxxxxxxxxxx
# OPENROUTER_API_KEY_3=sk-or-v1-xxxxxxxxxxxxx
# ... thêm bao nhiêu cũng được (tối đa 100 keys)

# ────────────────────────────────────────────────────────────
# GitHub OAuth App (TÙY CHỌN — cho push GitHub)
# Tạo app tại: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/github/callback
# ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=xxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxx

# ────────────────────────────────────────────────────────────
# App URL
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────
# SMTP (TỰ ĐỘNG từ leader — không cần config global)
# Leader nhập email + Gmail App Password trong form tạo project
# Lấy App Password: https://myaccount.google.com/apppasswords
# ────────────────────────────────────────────────────────────
