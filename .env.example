# ====== NEXUS AI — Environment Variables ======
# Copy file này thành .env và điền giá trị thật

# Database (SQLite)
DATABASE_URL=file:./db/custom.db

# DeepSeek API Keys (PRIORITY — dùng trước OpenRouter)
# Model: deepseek-chat (V4 Flash) + deepseek-reasoner (V4 Pro)
# Lấy tại: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_API_KEY_2=sk-xxx (dự phòng, tùy chọn)

# OpenRouter API Keys (FALLBACK — khi DeepSeek bị rate limit)
# Hỗ trợ không giới hạn số key — tự động luân chuyển
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx
# OPENROUTER_API_KEY_2=sk-or-v1-xxxxxxxxxxxxx
# OPENROUTER_API_KEY_3=sk-or-v1-xxxxxxxxxxxxx
# ... thêm bao nhiêu cũng được

# GitHub OAuth App (tùy chọn — cho push GitHub)
GITHUB_CLIENT_ID=xxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
