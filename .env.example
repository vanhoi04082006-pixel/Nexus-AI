# ====== NEXUS AI — Environment Variables ======
# Copy file này thành .env và điền giá trị thật

# Database (SQLite — lưu tại db/custom.db)
DATABASE_URL=file:./db/custom.db

# OpenRouter API Keys — hỗ trợ KHÔNG GIỚI HẠN số key
# Khi 1 key bị 429 (rate limit) hoặc 401/403 (invalid), tự động chuyển sang key tiếp theo
# Key phải đánh số liên tục: _2, _3, _4, _5, _6, ...
# Thêm bao nhiêu key cũng được — hệ thống tự detect tất cả
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx
# OPENROUTER_API_KEY_2=sk-or-v1-xxxxxxxxxxxxx
# OPENROUTER_API_KEY_3=sk-or-v1-xxxxxxxxxxxxx
# OPENROUTER_API_KEY_4=sk-or-v1-xxxxxxxxxxxxx
# OPENROUTER_API_KEY_5=sk-or-v1-xxxxxxxxxxxxx
# ... thêm bao nhiêu cũng được

# GitHub OAuth App credentials (tùy chọn — cho tính năng push GitHub)
# Tạo tại: https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/github/callback
GITHUB_CLIENT_ID=xxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxx

# App URL (script run-local sẽ tự cập nhật khi tunnel chạy)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
