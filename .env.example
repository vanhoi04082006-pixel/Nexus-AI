# ====== NEXUS AI — Environment Variables ======
# Copy file này thành .env và điền giá trị thật

# Database (SQLite — lưu tại db/custom.db)
DATABASE_URL=file:./db/custom.db

# OpenRouter API Keys — hỗ trợ nhiều key để tránh rate limit
# Khi 1 key bị 429 (rate limit) hoặc 401/403 (invalid), tự động chuyển sang key tiếp theo
# Thêm key 4, 5... bằng OPENROUTER_API_KEY_4, OPENROUTER_API_KEY_5, ...
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx
OPENROUTER_API_KEY_2=sk-or-v1-xxxxxxxxxxxxx
OPENROUTER_API_KEY_3=sk-or-v1-xxxxxxxxxxxxx

# GitHub OAuth App credentials (tạo tại https://github.com/settings/developers)
GITHUB_CLIENT_ID=xxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxx

# App URL (script run-local sẽ tự cập nhật khi tunnel chạy)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
