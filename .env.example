# ====== NEXUS AI — Environment Variables ======
# Copy file này thành .env và điền giá trị thật

# Database (SQLite — lưu tại db/custom.db)
DATABASE_URL=file:./db/custom.db

# OpenRouter API Key (lấy tại https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx

# GitHub OAuth App credentials (tạo tại https://github.com/settings/developers)
GITHUB_CLIENT_ID=xxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxx

# App URL (để tạo link trong email)
# Khi chạy local: http://localhost:3000
# Khi dùng Cloudflare Tunnel: https://xxx.trycloudflare.com (script tự cập nhật)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
