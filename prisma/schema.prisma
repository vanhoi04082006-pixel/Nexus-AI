// NEXUS AI - Multi-Agent Project Architect
// Database schema for project planning, collaboration, and task management

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  topic       String
  description String   @default("")
  purpose     String   @default("")
  extraInfo   String   @default("{}")
  status      String   @default("DRAFT")
  leaderName  String
  leaderEmail String   @default("")
  leaderToken String   @default(cuid())
  leaderSmtpPassword String?
  githubToken     String?
  githubUsername  String?
  githubRepoName  String?
  githubPushedAt  DateTime?
  // Dashboard enrichment fields
  isFavorite  Boolean  @default(false)
  isArchived  Boolean  @default(false)
  priority    String   @default("normal") // low | normal | high | urgent
  deadline    DateTime?
  techStack   String   @default("[]") // JSON array: ["Next.js","React","PostgreSQL"]
  tags        String   @default("[]") // JSON array: ["web","ecommerce"]
  coverColor  String   @default("cyan") // cyan | emerald | purple | amber | rose | blue
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       Member[]
  analyses      Analysis[]
  chatMessages  ChatMessage[]
  tasks         Task[]
  emails        EmailLog[]
  editProposals EditProposal[]
  context       ProjectContext?
  tokenLogs     TokenLog[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  agentConfigs  AgentConfig[]
  mailEmails    Email[]
}

/// Long-term memory cache for a project.
/// After the first pipeline run, we store a compressed context here.
/// On subsequent runs (retry/refine), AI loads this context instead of
/// re-reading everything from scratch — saves tokens + time.
model ProjectContext {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Compressed JSON: { topic, modules, techStack, actors, members, assignments, sprints }
  /// This is the "long memory" — AI reads this instead of full results.
  summary     String
  /// Full results JSON (all 7 sections) — cached for instant reload
  fullResults String?
  /// Token count estimate of the last pipeline run
  tokensUsed  Int      @default(0)
  /// How many times this project has been analyzed
  runCount    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Token usage log — track API costs per agent per project
model TokenLog {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentId     String   // e.g. "01", "02", ..., "08", "task-gen", "chat"
  agentName   String   // e.g. "Requirement Analyst"
  model       String   // e.g. "openai/gpt-oss-120b:free"
  apiKeyId    Int      // which API key was used (1, 2, 3, ...)
  promptTokens  Int    @default(0)
  completionTokens Int @default(0)
  totalTokens   Int    @default(0)
  success     Boolean  @default(true)
  errorMsg    String?
  duration    Int      @default(0) // milliseconds
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([agentId])
}

model Member {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  email       String
  strengths   String   @default("")
  weaknesses  String   @default("")
  role        String   @default("") // assigned role from HR analysis
  inviteToken String   @default(cuid()) // for member access via link
  joinedAt    DateTime?
  createdAt   DateTime @default(now())

  tasks         Task[]
  chatMessages  ChatMessage[]
  editProposals EditProposal[]

  @@index([projectId])
  @@index([inviteToken])
}

// A versioned analysis section. type: ANALYSIS | HR | SPRINT | DESIGN | UML | DOCS | GIT
model Analysis {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  content   String   @default("{}") // JSON content of the section
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([projectId, type])
  @@index([projectId])
}

// Edit proposals raised during chat discussions; leader approves -> applied via AI refine
model EditProposal {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memberId        String?
  member          Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  section         String   // ANALYSIS | HR | SPRINT | DESIGN | UML | DOCS | GIT
  requestedChange String   // human-readable description of the requested change
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED | APPLIED
  createdAt       DateTime @default(now())

  @@index([projectId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memberId  String?
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  authorName String
  authorRole String  @default("member") // leader | member | ai
  message   String
  createdAt DateTime @default(now())

  @@index([projectId])
}

// Detailed task in the todolist — SMART model with technical hints
model Task {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memberId        String?
  member          Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  assigneeName    String   @default("")
  title           String
  description     String   @default("")
  role            String   @default("")
  responsibilities String  @default("")
  codeConventions String   @default("")
  dependencies    String   @default("")
  acceptanceCriteria String @default("")
  deadline        DateTime?
  sprintName      String   @default("")
  status          String   @default("todo")
  hours           Int      @default(8)
  priority        String   @default("P1")
  // New fields for Kanban + Developer-First model
  layer           String   @default("BACKEND") // DATABASE | BACKEND | UI | CONFIG | TESTING
  targetFile      String   @default("") // file/class/namespace cần can thiệp
  implementationSteps String @default("[]") // JSON array of step strings
  technicalHints  String   @default("{}") // JSON { snippet, note }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([memberId])
}

// Mock mailbox: stores emails that would be sent to members
model EmailLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  toEmail   String
  toName    String   @default("")
  subject   String
  body      String
  type      String   // INVITATION | REMINDER | TASK_ASSIGNED
  sentAt    DateTime @default(now())

  @@index([projectId])
}

// Activity log: stores all pipeline/init/refine logs + success/failure events.
// Enriched with actor info + relations so the dashboard "Recent Activity" widget
// can show who did what, on which project/task, with a clickable link.
model ActivityLog {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String   // PROJECT_CREATED | PROJECT_UPDATED | PROJECT_DELETED | MEMBER_JOINED | MEMBER_LEFT | TASK_CREATED | TASK_UPDATED | TASK_STATUS_CHANGED | TASK_COMPLETED | DOC_UPLOADED | AI_AGENT_START | AI_AGENT_DONE | AI_AGENT_ERROR | SPRINT_CREATED | DEPLOY | GIT_MERGE | PROPOSAL_CREATED | PROPOSAL_APPROVED | PROPOSAL_REJECTED | MAIL_SENT | MAIL_RECEIVED | PIPELINE | INIT | REFINE | TASK_GEN | SECTION_EDIT | GITHUB_PUSH | EMAIL_SENT
  status      String   @default("SUCCESS") // SUCCESS | FAILED | RUNNING | WARNING
  title       String   // Short summary
  details     String   @default("")
  // Actor info (who triggered the event)
  actorName   String   @default("")
  actorEmail  String   @default("")
  actorRole   String   @default("") // Leader | Member | AI Agent | System
  actorAvatar String   @default("") // optional avatar URL or initials
  // Relations
  relatedTaskId    String?
  relatedTaskTitle String   @default("")
  relatedMailId    String?
  actionUrl   String   @default("") // click-through link
  actionLabel String   @default("")
  icon        String   @default("Activity") // lucide icon name for the activity type
  // Legacy pipeline/AI fields (nullable, kept for backward compat)
  agentId     String?
  model       String?
  duration    Int?
  logCount    Int?
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([type])
  @@index([createdAt])
  @@index([actorEmail])
}

// Task change history — audit trail of every task mutation.
model TaskLog {
  id          String   @id @default(cuid())
  taskId      String
  projectId   String
  action      String   // CREATED | UPDATED | STATUS_CHANGED | COMPLETED | ASSIGNED | DEADLINE_CHANGED
  oldStatus   String?
  newStatus   String?
  actorName   String   @default("")
  actorEmail  String   @default("")
  details     String   @default("")
  createdAt   DateTime @default(now())

  @@index([taskId])
  @@index([projectId])
  @@index([createdAt])
}

// Live AI agent status — updated whenever an agent starts/finishes/errors.
// Falls back to AgentConfig if no row exists for an agentId.
model AgentStatus {
  id          String   @id @default(cuid())
  agentId     String   @unique // "01".."10" | custom
  name        String
  role        String   @default("")
  status      String   @default("idle") // online | offline | busy | error | idle
  currentTask String   @default("") // what it's doing right now
  projectId   String?
  lastActiveAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([projectId])
}

// System status — key/value rows for db/redis/vectorDB/storage.
// One row per subsystem. status: connected | disconnected | ready | error | etc.
model SystemStatus {
  id          String   @id @default(cuid())
  subsystem   String   @unique // database | redis | vector_db | storage | pipeline
  status      String   @default("unknown") // connected | disconnected | ready | running | paused | failed | deploying | success | unknown
  details     String   @default("") // e.g. "SQLite @ /db/custom.db" or "12.4 MB used"
  metadata    String   @default("{}") // JSON for extra info (usage %, latency, etc.)
  updatedAt   DateTime @updatedAt
}

// Pipeline status — one row per running/recent pipeline per project.
model PipelineStatus {
  id          String   @id @default(cuid())
  projectId   String
  status      String   @default("ready") // ready | running | paused | failed | deploying | success
  currentAgent String  @default("") // agent currently working
  progress    Int      @default(0) // 0-100
  stage       String   @default("") // ANALYSIS | HR | SPRINT | DESIGN | UML | DOCS | GIT | TASK_GEN
  startedAt   DateTime?
  finishedAt  DateTime?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([status])
}

// Task statistics snapshot — cached aggregate per project (refreshed on task changes).
model TaskStatistic {
  id              String   @id @default(cuid())
  projectId       String   @unique
  totalTasks      Int      @default(0)
  doneTasks       Int      @default(0)
  inProgressTasks Int      @default(0)
  todoTasks       Int      @default(0)
  reviewTasks     Int      @default(0)
  overdueTasks    Int      @default(0)
  dueSoonTasks    Int      @default(0) // deadline within 24h
  completionRate  Float    @default(0.0) // doneTasks/totalTasks * 100
  updatedAt       DateTime @updatedAt
}

// Notifications — bell icon alerts (task completions, proposals, mails, deadlines, etc.)
// Per-user read tracking is done via NotificationRead (one row per reader).
// recipientEmail: null = broadcast to everyone in the project; otherwise targeted.
model Notification {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type          String   // TASK_COMPLETED | TASK_STATUS_CHANGED | PROPOSAL_CREATED | REQUIREMENT_EDITED | DOC_UPLOADED | COMMENT | AI_DONE | AI_ERROR | DEADLINE_SOON | TASK_ASSIGNED | MAIL_RECEIVED | PROJECT_INVITE | APPROVAL_REQUEST | ACTIVITY
  title         String
  message       String   @default("")
  // Enriched fields for the Detail Panel
  senderName    String   @default("")   // who/what triggered it (member name or "AI Agent 03")
  senderRole    String   @default("")   // member role or "AI" / "SYSTEM"
  recipientEmail String? // null = broadcast to whole project; otherwise a specific user's email
  priority      String   @default("normal") // low | normal | high | urgent
  relatedTaskId String?  // optional task reference
  relatedTaskTitle String @default("")
  relatedMailId String?  // optional email reference
  actionUrl     String   @default("")   // link to navigate to (e.g. "/?p=ID&token=TOKEN")
  actionLabel   String   @default("")   // button label e.g. "Mở Task", "Đọc Email"
  extra         String   @default("{}") // JSON for any additional context
  // Legacy field kept for backward compat — not used for per-user read tracking
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  readBy        NotificationRead[]

  @@index([projectId])
  @@index([recipientEmail])
  @@index([type])
  @@index([createdAt])
}

// Per-user read receipt for notifications.
// A notification is "unread" for a user when no NotificationRead row exists.
model NotificationRead {
  id            String   @id @default(cuid())
  notificationId String
  notification  Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  readerEmail   String   // email of the user who read it (leader or member)
  readAt        DateTime @default(now())

  @@unique([notificationId, readerEmail])
  @@index([readerEmail])
}

// Agent configuration — customizable AI agents
model AgentConfig {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentId     String   // "01".."10" | custom
  name        String
  role        String   // Architect, Backend, Frontend, etc.
  description String   @default("")
  model       String   @default("openai/gpt-oss-120b:free")
  provider    String   @default("openrouter")
  temperature Float    @default(0.2)
  maxContext  Int      @default(8000)
  status      String   @default("online") // online | offline | busy | error
  systemPrompt String  @default("")
  skills      String   @default("[]") // JSON array of skill names
  tokenUsed   Int      @default(0)
  taskCount   Int      @default(0)
  successRate Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([agentId])
}

// Project template — blueprint for quick project creation
model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String   // WEB | ECOMMERCE | MANAGEMENT | MOBILE | LMS | HOTEL | HOSPITAL | WAREHOUSE | BANKING | AI_SAAS | CHAT | MICROSERVICES | K8S | DASHBOARD | CUSTOM
  icon        String   @default("Code2")
  color       String   @default("from-cyan-500/20 to-blue-600/5")
  topic       String
  purpose     String   @default("Đồ án tốt nghiệp")
  techPrefs   String   @default("")
  langPrefs   String   @default("")
  isBuiltIn   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([category])
}

// ===== MAIL SYSTEM =====
// Email stores the actual email content (one row per email sent).
// Per-user state (folder, read, starred) is in Mailbox.
model Email {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromEmail   String
  fromName    String   @default("")
  // JSON arrays of email addresses (SQLite has no native array)
  toEmails    String   @default("[]")  // JSON: ["a@x.com","b@y.com"]
  ccEmails    String   @default("[]")
  bccEmails   String   @default("[]")
  subject     String
  bodyHtml    String   @default("")
  bodyText    String   @default("")
  type        String   @default("COMPOSE") // COMPOSE | INVITATION | TASK_ASSIGNED | REMINDER | REPLY | FORWARD
  // SMTP delivery status
  smtpStatus  String   @default("pending") // pending | sent | failed | logged_only
  smtpError   String?
  smtpMessageId String?
  // Threading: reply/forward chain
  parentEmailId String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attachments  EmailAttachment[]
  mailboxes    Mailbox[]
  readReceipts MailRead[]

  @@index([projectId])
  @@index([fromEmail])
  @@index([parentEmailId])
  @@index([createdAt])
}

// Email attachment — stored as base64 content (SQLite blob alternative)
model EmailAttachment {
  id          String   @id @default(cuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename    String
  mimeType    String   @default("application/octet-stream")
  size        Int      @default(0)   // bytes
  content     String   // base64-encoded file content
  createdAt   DateTime @default(now())

  @@index([emailId])
}

// Per-user mailbox state. One row per (email, user).
// folder: INBOX | SENT | DRAFT | STARRED | TRASH | ARCHIVE | SPAM
// (STARRED is a flag; folder is the primary location. We keep folder + isStarred separate
//  so a starred mail in INBOX stays in INBOX but shows in the Starred view too.)
model Mailbox {
  id          String   @id @default(cuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  userEmail   String   // the user this mailbox row belongs to (leader or member email)
  folder      String   @default("INBOX") // INBOX | SENT | DRAFT | TRASH | ARCHIVE | SPAM
  isRead      Boolean  @default(false)
  isStarred   Boolean  @default(false)
  isArchived  Boolean  @default(false)
  isTrashed   Boolean  @default(false)
  readAt      DateTime?
  trashedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([emailId, userEmail])
  @@index([userEmail])
  @@index([folder])
  @@index([emailId])
}

// Read receipt audit log (separate from Mailbox.isRead for history tracking)
model MailRead {
  id          String   @id @default(cuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  userEmail   String
  readAt      DateTime @default(now())
  via         String   @default("MAILBOX") // MAILBOX | NOTIFICATION

  @@unique([emailId, userEmail])
  @@index([userEmail])
}
