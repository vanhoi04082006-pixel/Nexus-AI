upload/

# Scripts sandbox
scripts/
.zscripts/

# Documentation (không cần trong image)
agent-ctx/
tool-results/
worklog.md
download/

# IDE
.vscode
.idea
*.swp

# OS
.DS_Store
Thumbs.db

