# ====== NEXUS AI Chat Service — Fly.io Dockerfile ======
FROM oven/bun:1.2-slim

WORKDIR /app

# Copy package files
COPY mini-services/chat-service/package.json ./
COPY mini-services/chat-service/bun.lock* ./

# Install dependencies
RUN bun install

# Copy source
COPY mini-services/chat-service/ ./

# Set environment
ENV PORT=3001
ENV NODE_ENV=production

# Expose port
EXPOSE 3001

# Start
CMD ["bun", "run", "dev"]
